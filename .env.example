# Local development — copy to `.env` in the project root:
#   cp .env.example .env
# Then fill in values. `.env` is gitignored.

# Required for order notification emails (Order page → /api/send-order-email)
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: where order emails are delivered (default: cchadww@gmail.com)
# ORDER_NOTIFICATION_EMAIL=you@example.com

# Sender (Resend). Without a verified domain, local dev now defaults to onboarding@resend.dev automatically.
# For production, verify williamscreekfarms.com at https://resend.com/domains or set e.g.:
# RESEND_FROM=Southwest Iowa Hedge <orders@williamscreekfarms.com>

# Used by Stripe checkout success/cancel URLs (deposit flow)
SITE_URL=http://localhost:4321

# Only needed if you test the 10% deposit + Stripe redirect locally
# STRIPE_SECRET_KEY=sk_test_...
