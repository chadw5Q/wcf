# Google Analytics 4 — optional; enables gtag on all pages + conversion events on /thank-you and /success
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Local development — copy to `.env` in the project root:
#   cp .env.example .env
# Then fill in values. `.env` is gitignored.

# Required for order notification emails (Order page → /api/send-order-email)
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: where order emails are delivered (default: cchadww@gmail.com)
# ORDER_NOTIFICATION_EMAIL=you@example.com

# Sender (Resend). Without a verified domain, local dev now defaults to onboarding@resend.dev automatically.
# For production, verify williamscreekfarms.com at https://resend.com/domains or set e.g.:
# RESEND_FROM=Southwest Iowa Hedge <orders@williamscreekfarms.com>

# Used by Stripe checkout success/cancel URLs (deposit flow)
SITE_URL=http://localhost:4321

# Only needed if you test the 10% deposit + Stripe redirect locally
# STRIPE_SECRET_KEY=sk_test_...

# ntfy.sh push alerts when orders are placed (default topic: https://ntfy.sh/hedge-order)
# Private topic: create an access token in the ntfy app and set:
# NTFY_ACCESS_TOKEN=tk_...
# Optional override URL:
# NTFY_TOPIC_URL=https://ntfy.sh/your-topic
# Disable in tests: NTFY_DISABLE=1

# Cal.com → ntfy (separate Cloudflare Worker; not Astro .env). See workers/cal-ntfy-worker/README.md

# --- Orders KV (production) ---
# Bind ORDERS_KV in wrangler.jsonc with your namespace id from:
#   npx wrangler kv namespace create ORDERS_KV
# Local `astro dev` does not attach KV unless you use wrangler dev or wire a preview id.

# --- /admin orders mini-app ---
# ADMIN_PASSWORD=choose-a-strong-password
# Optional: separate signing secret for cookies (defaults to ADMIN_PASSWORD if unset)
# ADMIN_SESSION_SECRET=long-random-string
