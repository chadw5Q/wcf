---
import '../styles/global.css';

export interface Props {
  title: string;
  /** Meta description (search snippets). ~150–160 chars recommended. */
  description?: string;
  /** Open Graph / Twitter share description; defaults to `socialDescription` then `description`. */
  ogDescription?: string;
  /** Open Graph title; defaults to `title`. */
  ogTitle?: string;
  /** Absolute or site-root path for og:image and twitter:image */
  image?: string;
  /** Override canonical URL (string path or full URL) */
  canonicalURL?: string | URL;
  /** Merge into JSON-LD @graph after LocalBusiness */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  /** Prevent search indexing (e.g. payment success) */
  noindex?: boolean;
}

const DEFAULT_META_DESCRIPTION =
  'Buy premium Osage Orange hedge posts direct from our Southwest Iowa farm. Proven 50+ year durability for permanent fencing. Fresh cut, ready to ship. Order now.';

const {
  title,
  description = DEFAULT_META_DESCRIPTION,
  ogDescription,
  ogTitle,
  image = '/images/hedge002.jpg',
  canonicalURL: canonicalProp,
  structuredData,
  noindex = false,
} = Astro.props;

const siteHref = Astro.site?.href ?? 'https://williamscreekfarms.com/';
const siteOrigin = new URL(siteHref).origin;

const path = Astro.url.pathname || '/';
const canonical =
  canonicalProp !== undefined
    ? new URL(canonicalProp, siteOrigin)
    : new URL(path, siteOrigin);

const absoluteImage = new URL(image, siteOrigin).href;
const metaOgTitle = ogTitle ?? title;
const metaOgDescription = ogDescription ?? description;

const localBusiness = {
  '@type': 'LocalBusiness',
  name: 'Southwest Iowa Hedge',
  legalName: 'Williams Creek Farms, LLC',
  image: `${siteOrigin}/images/hedge002.jpg`,
  url: siteOrigin,
  telephone: '+17122543999',
  email: 'cchadww@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1100 Apple Ave',
    addressLocality: 'Cumberland',
    addressRegion: 'IA',
    postalCode: '50843',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 41.2742,
    longitude: -95.2511,
  },
  priceRange: '$$',
  areaServed: ['Iowa', 'Missouri', 'Nebraska'],
  description:
    'Premium Osage Orange hedge posts for permanent fencing and traditional bow stave logs. Fresh cut in Southwest Iowa.',
};

const graph: Record<string, unknown>[] = [localBusiness];
if (structuredData) {
  const extra = Array.isArray(structuredData) ? structuredData : [structuredData];
  graph.push(...extra);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonical.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Southwest Iowa Hedge" />
    <meta property="og:title" content={metaOgTitle} />
    <meta property="og:description" content={metaOgDescription} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaOgTitle} />
    <meta name="twitter:description" content={metaOgDescription} />
    <meta name="twitter:image" content={absoluteImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <div class="flex-shrink-0">
            <a href="/" class="flex items-center space-x-2">
              <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-sm">S</span>
              </div>
              <span class="text-xl font-bold text-gray-900">Southwest Iowa Hedge</span>
            </a>
          </div>

          <!-- Desktop Navigation -->
          <div class="hidden md:block">
            <div class="ml-10 flex items-baseline space-x-8">
              <a
                href="/"
                class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === '/' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600'}`}
              >
                Hedge Posts
              </a>
              <a
                href="/osage-bow-staves"
                class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === '/osage-bow-staves' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600'}`}
              >
                Osage Bow Staves
              </a>
              <a
                href="/order-now"
                class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === '/order-now' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600'}`}
              >
                Order Now
              </a>
              <a
                href="/contact"
                class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === '/contact' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600'}`}
              >
                Contact
              </a>
            </div>
          </div>

          <!-- Mobile menu button -->
          <div class="md:hidden">
            <button
              type="button"
              class="mobile-menu-button bg-white p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-green-500"
            >
              <span class="sr-only">Open main menu</span>
              <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <div class="mobile-menu hidden md:hidden">
        <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white border-t border-gray-200">
          <a
            href="/"
            class={`block px-3 py-2 rounded-md text-base font-medium ${currentPath === '/' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600 hover:bg-gray-50'}`}
          >
            Hedge Posts
          </a>
          <a
            href="/osage-bow-staves"
            class={`block px-3 py-2 rounded-md text-base font-medium ${currentPath === '/osage-bow-staves' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600 hover:bg-gray-50'}`}
          >
            Osage Bow Staves
          </a>
          <a
            href="/order-now"
            class={`block px-3 py-2 rounded-md text-base font-medium ${currentPath === '/order-now' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600 hover:bg-gray-50'}`}
          >
            Order Now
          </a>
          <a
            href="/contact"
            class={`block px-3 py-2 rounded-md text-base font-medium ${currentPath === '/contact' ? 'text-green-600 bg-green-50' : 'text-gray-700 hover:text-green-600 hover:bg-gray-50'}`}
          >
            Contact
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Company Info -->
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center space-x-2 mb-4">
              <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-sm">S</span>
              </div>
              <span class="text-xl font-bold">Southwest Iowa Hedge</span>
            </div>
            <p class="text-gray-300 mb-4 max-w-md">
              Premium hedge posts for permanent fencing and traditional archery bow staves. Fresh cut hedge posts from Southwest Iowa, serving Iowa, Missouri, and Nebraska.
            </p>
            <div class="flex flex-wrap items-center gap-4">
              <a
                href="mailto:cchadww@gmail.com"
                class="inline-flex items-center text-gray-400 hover:text-white transition-colors"
              >
                <svg class="h-6 w-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
                Email us
              </a>
              <a
                href="tel:+17122543999"
                class="inline-flex items-center text-gray-400 hover:text-white transition-colors"
              >
                <svg class="h-6 w-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  />
                </svg>
                Text or call 712-254-3999
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4">Quick Links</h3>
            <ul class="space-y-2">
              <li><a href="/" class="text-gray-300 hover:text-white transition-colors">Hedge Posts</a></li>
              <li><a href="/osage-bow-staves" class="text-gray-300 hover:text-white transition-colors">Osage Bow Staves</a></li>
              <li><a href="/order-now" class="text-gray-300 hover:text-white transition-colors">Order Now</a></li>
              <li><a href="/contact" class="text-gray-300 hover:text-white transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div>
            <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4">Contact</h3>
            <ul class="space-y-2 text-gray-300">
              <li>Email: cchadww@gmail.com</li>
              <li>Phone: 712-254-3999</li>
            </ul>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-gray-800">
          <p class="text-gray-400 text-sm text-center">
            © 2025 Williams Creek Farms, LLC. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const mobileMenuButton = document.querySelector('.mobile-menu-button');
        const mobileMenu = document.querySelector('.mobile-menu');

        if (mobileMenuButton && mobileMenu) {
          mobileMenuButton.addEventListener('click', function () {
            mobileMenu.classList.toggle('hidden');
          });
        }
      });
    </script>
  </body>
</html>
