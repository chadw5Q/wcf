---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Osage Bow Staves - Southwest Iowa Hedge" description="Premium osage orange bow stave logs for traditional archery. Hand-selected logs yielding 3-8 bow staves per log. Ends painted within 24 hours of cutting.">
  <!-- Hero Section -->
  <section class="section-padding bg-gradient-to-br from-green-800 to-green-900 text-white relative">
    <div class="absolute inset-0 bg-black bg-opacity-30"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Osage Orange Bow Staves
      </h1>
      <p class="text-xl md:text-2xl mb-8 text-green-100">
        Premium hedge wood for traditional archery enthusiasts
      </p>
      <div class="bg-green-600 bg-opacity-80 rounded-xl p-6 inline-block">
        <p class="text-lg font-semibold">
          One of the finest woods for crafting traditional longbows
        </p>
      </div>
    </div>
  </section>

  <!-- Why Osage Orange Section -->
  <section class="section-padding bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Why Osage Orange for Traditional Bows?
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Osage orange (also known as hedge, bodark, or bois d'arc) has been prized by bowyers for centuries. 
          Native Americans called it the "bow wood" for good reason.
        </p>
      </div>

      <figure class="mt-12 mb-4 mx-auto max-w-4xl">
        <img
          src="/images/hedge-bowstave007.jpg"
          alt="Osage orange hedge bow stave logs"
          class="w-full rounded-xl shadow-lg object-cover max-h-[min(28rem,70vh)]"
          loading="eager"
          decoding="async"
        />
      </figure>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-green-50 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Exceptional Strength</h3>
          <p class="text-gray-700">
            One of the strongest woods available, with incredible tensile strength that makes powerful, fast-shooting bows.
          </p>
        </div>

        <div class="bg-green-50 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13a1 1 0 102 0V9.414l1.293 1.293a1 1 0 001.414-1.414z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Natural Elasticity</h3>
          <p class="text-gray-700">
            Perfect balance of flexibility and snap-back that delivers smooth draw and lightning-fast arrow release.
          </p>
        </div>

        <div class="bg-green-50 rounded-xl p-6 text-center">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Dense Grain</h3>
          <p class="text-gray-700">
            Tight, consistent grain structure provides reliable performance and beautiful finished appearance.
          </p>
        </div>
      </div>

      <div class="flex justify-center mt-12">
        <a href="/order-now" class="inline-flex bg-green-600 text-white hover:bg-green-700 font-semibold py-3 px-8 rounded-lg transition-colors duration-200 shadow-md">
          Order Now
        </a>
      </div>
    </div>
  </section>

  <!-- Our Process Section -->
  <section class="section-padding bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Our Premium Bow Stave Process
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We take special care in preparing our osage orange logs specifically for bow stave use, 
          ensuring you get the highest quality wood for your traditional archery projects.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Hand-Selected Logs</h3>
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="w-6 h-6 text-green-600 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-gray-900">Premium Grade Selection</h4>
                <p class="text-gray-700">We carefully choose the straightest, most knot-free sections of mature osage orange trees.</p>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="w-6 h-6 text-green-600 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-gray-900">Optimal Diameter</h4>
                <p class="text-gray-700">Usually around 6" diameter, perfect size for yielding multiple quality staves.</p>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="w-6 h-6 text-green-600 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-gray-900">Minimum 6 Feet Long</h4>
                <p class="text-gray-700">Length suitable for full-size traditional longbows with room for shaping.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-8 shadow-lg">
          <div class="text-center">
            <div class="text-5xl font-bold text-green-600 mb-2">3-8</div>
            <p class="text-xl text-gray-700 font-semibold mb-4">Bow Staves Per Log</p>
            <p class="text-gray-600">
              Each log typically yields multiple high-quality staves, giving you options for different bow designs 
              or backup material for your projects.
            </p>
          </div>
        </div>
      </div>

      <!-- Preservation Process -->
      <div class="bg-white rounded-xl p-8 shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-white font-bold text-xl">24hr</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">End Sealing</h3>
            <p class="text-gray-700">
              We paint the cut ends within 24 hours of cutting to prevent checking and preserve the wood's integrity.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Quality Control</h3>
            <p class="text-gray-700">
              Each log is inspected for defects, ensuring you receive only the finest quality osage orange.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Personal Selection</h3>
            <p class="text-gray-700">
              You can choose the specific log that appeals to you, ensuring you get exactly what you want for your project.
            </p>
          </div>
        </div>
      </div>

      <div class="flex justify-center mt-10">
        <a href="/order-now" class="inline-flex bg-green-600 text-white hover:bg-green-700 font-semibold py-3 px-8 rounded-lg transition-colors duration-200 shadow-md">
          Order Now
        </a>
      </div>

      <p class="mt-8 text-center text-gray-600 italic max-w-3xl mx-auto">
        Important: We cannot ship bow stave logs - pickup only
      </p>
    </div>
  </section>

  <!-- Additional Info Section -->
  <section class="section-padding bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-8">Traditional Archery Heritage</h2>
      <p class="text-xl text-gray-300 mb-8">
        Native Americans recognized osage orange as the ultimate bow wood. Today's traditional archers continue this legacy, 
        crafting powerful, accurate longbows from this legendary timber. When you choose our osage orange bow stave logs, 
        you're connecting with centuries of archery tradition.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="text-center">
          <div class="text-4xl mb-3">🏹</div>
          <h3 class="text-xl font-bold mb-2">Traditional</h3>
          <p class="text-gray-400">Time-tested by generations of bowyers</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">💪</div>
          <h3 class="text-xl font-bold mb-2">Powerful</h3>
          <p class="text-gray-400">Exceptional strength and performance</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🎯</div>
          <h3 class="text-xl font-bold mb-2">Accurate</h3>
          <p class="text-gray-400">Consistent, reliable shooting characteristics</p>
        </div>
      </div>
    </div>
  </section>
</Layout>