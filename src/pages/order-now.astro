---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Order Now - Southwest Iowa Hedge">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-green-600 to-green-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Order Your Hedge Posts
        </h1>
        <p class="text-xl text-green-100 max-w-3xl mx-auto">
          Ready to get started with your fencing project? Place your order today 
          and secure your fresh cut hedge posts.
        </p>
      </div>
    </div>
  </section>

  <!-- Order Form and Info -->
  <section class="section-padding bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Order Form -->
        <div class="space-y-8">
          <!-- Order Process -->
          <div class="card">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Order Process</h3>
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-green-600 text-white rounded-full flex items-center justify-center flex-shrink-0 mt-1 text-sm font-bold">
                  1
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Place Your Order</h4>
                  <p class="text-gray-600 text-sm">Fill out the form with your requirements</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-green-600 text-white rounded-full flex items-center justify-center flex-shrink-0 mt-1 text-sm font-bold">
                  2
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Order Confirmation and Schedule Pickup</h4>
                  <p class="text-gray-600 text-sm">We'll contact you within 24 hours to confirm details</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-green-600 text-white rounded-full flex items-center justify-center flex-shrink-0 mt-1 text-sm font-bold">
                  3
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Choose Your Hedge and Final Payment</h4>
                  <p class="text-gray-600 text-sm">Select your specific posts at our farm and pay remaining balance</p>
                </div>
              </div>
            </div>
          </div>

          <div class="card">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Place Your Order</h2>
          
            <form id="order-form" class="space-y-6">
            <!-- Discount Note -->
            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
              <p class="text-yellow-800 text-sm">
                <strong>Note:</strong> Orders over 100 posts qualify for a 10% discount automatically applied below.
              </p>
            </div>
            
            <!-- Post Types and Quantities -->
            <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">What would you like to order?</h3>
              <p class="text-sm text-gray-700 mb-4">Don't worry, you can come to our farm and pick out your posts before paying the full amount.  <strong>Payment NOT required now.</strong></p>
              
              <!-- Premium Line Posts -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 p-4 bg-white rounded-lg border">
                <div>
                  <h4 class="font-medium text-gray-900">Premium Line Posts - $25</h4>
                  <p class="text-sm text-gray-600">3-6" diameter, relatively straight, 9ft long</p>
                </div>
                <div>
                  <label for="premiumLine" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                  <input type="number" id="premiumLine" name="premiumLine" min="0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
              </div>
              
              <!-- Premium Corner Posts -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 p-4 bg-white rounded-lg border">
                <div>
                  <h4 class="font-medium text-gray-900">Premium Corner/Second Posts - $40</h4>
                  <p class="text-sm text-gray-600">6-12" diameter, relatively straight, 9ft long</p>
                </div>
                <div>
                  <label for="premiumCorner" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                  <input type="number" id="premiumCorner" name="premiumCorner" min="0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
              </div>
              
              <!-- Premium Extra Long Posts (sold out) -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 p-4 bg-gray-50 rounded-lg border border-red-200 relative">
                <div class="absolute top-3 right-3">
                  <span class="bg-red-600 text-white text-xs font-bold px-2 py-1 rounded-full">SOLD OUT</span>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Premium Extra Long Posts - $60</h4>
                  <p class="text-sm text-gray-600">At least 12' long, relatively straight</p>
                  <p class="text-sm text-red-600 font-medium mt-2">Currently unavailable — check back later.</p>
                </div>
                <div>
                  <label for="premiumExtraLong" class="block text-sm font-medium text-gray-500 mb-1">Quantity</label>
                  <input type="number" id="premiumExtraLong" name="premiumExtraLong" min="0" value="0" disabled class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-gray-100 text-gray-500 cursor-not-allowed" aria-disabled="true" title="Sold Out">
                </div>
              </div>
              
              <!-- Regular Line Posts -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 p-4 bg-white rounded-lg border">
                <div>
                  <h4 class="font-medium text-gray-900">Regular Line Posts - $10</h4>
                  <p class="text-sm text-gray-600">3-6" diameter, curvy or smaller, 9ft long</p>
                </div>
                <div>
                  <label for="regularLine" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                  <input type="number" id="regularLine" name="regularLine" min="0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
              </div>
              
              <!-- Regular Corner Posts -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 p-4 bg-white rounded-lg border">
                <div>
                  <h4 class="font-medium text-gray-900">Regular Corner Posts - $25</h4>
                  <p class="text-sm text-gray-600">8-14" diameter, curvy, 9ft long</p>
                </div>
                <div>
                  <label for="regularCorner" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                  <input type="number" id="regularCorner" name="regularCorner" min="0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
              </div>
              
              <!-- Bow Stave Logs -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 p-4 bg-white rounded-lg border">
                <div>
                  <h4 class="font-medium text-gray-900">Traditional Bow Stave Logs - $125</h4>
                  <p class="text-sm text-gray-600">6" diameter, 6ft+ long, no knots (pickup only)</p>
                </div>
                <div>
                  <label for="bowStave" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                  <input type="number" id="bowStave" name="bowStave" min="0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
              </div>
            </div>
            
            <!-- Order Summary -->
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Order Summary</h3>
              
              <div id="order-summary" class="space-y-2">
                <div class="text-gray-600 text-sm">Select post quantities above to see your total</div>
              </div>
              
              <div class="border-t pt-4 mt-4">
                <div class="flex justify-between items-center text-lg font-semibold">
                  <span>Total:</span>
                  <span id="order-total">$0.00</span>
                </div>
                <div id="discount-applied" class="text-green-600 text-sm mt-1 hidden">
                  10% volume discount applied!
                </div>
              </div>
            </div>
            
            <!-- Deposit Option -->
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mt-6">
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="flex-grow">
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">Secure Your Order with a Deposit (Optional)</h3>
                  <p class="text-gray-700 text-sm mb-4">
                    Due to limited supply, we recommend placing a 10% deposit to secure your order in the queue. 
                    This ensures your hedge posts will be reserved when they're ready for pickup.
                  </p>
                  
                  <div class="flex items-center space-x-3">
                    <label class="flex items-center cursor-pointer">
                      <input 
                        type="checkbox" 
                        id="deposit-option" 
                        class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                      >
                      <span class="ml-2 text-sm font-medium text-gray-900">
                        Yes, I want to place a 10% deposit to secure my order
                      </span>
                    </label>
                  </div>
                  
                  <div id="deposit-details" class="hidden mt-4 p-4 bg-white border border-blue-200 rounded-lg">
                    <div class="flex justify-between items-center mb-2">
                      <span class="text-sm text-gray-700">Order Total:</span>
                      <span id="deposit-order-total" class="text-sm font-medium">$0.00</span>
                    </div>
                    <div class="flex justify-between items-center mb-3">
                      <span class="text-sm font-semibold text-gray-900">10% Deposit Amount:</span>
                      <span id="deposit-amount" class="text-sm font-bold text-blue-600">$0.00</span>
                    </div>
                    <div class="text-xs text-gray-600">
                      <p>• Deposit secures your place in our production queue</p>
                      <p>• Remaining balance due at pickup</p>
                      <p>• You'll be redirected to secure payment page after submitting</p>
                      <p>• Credit card processed securely through Stripe</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Personal Information -->
            <div class="border-t pt-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Your Information</h3>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
                    First Name *
                  </label>
                  <input 
                    type="text" 
                    id="firstName" 
                    name="firstName" 
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                  >
                </div>
                
                <div>
                  <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
                    Last Name *
                  </label>
                  <input 
                    type="text" 
                    id="lastName" 
                    name="lastName" 
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                  >
                </div>
              </div>
              
              <div class="mt-4">
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  Email Address *
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email"
                  required
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                >
              </div>
              
              <div class="mt-4">
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                  Cell Phone Number *
                </label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  required
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                >
              </div>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                Additional Details
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                placeholder="Any specific requirements, delivery preferences, or questions..."
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
              ></textarea>
            </div>
            
            <div id="payment-notice" class="hidden bg-blue-50 border border-blue-200 rounded-lg p-3 mb-4">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm text-blue-800">You'll be redirected to Stripe's secure payment page to enter your credit card information.</span>
              </div>
            </div>
            
            <button 
              type="submit" 
              class="w-full btn-primary py-3 text-lg"
              id="submit-button"
            >
              Submit Order Request
            </button>
          </form>
          </div>
        </div>
        
        <!-- Order Information -->
        <div class="space-y-8">
          <!-- Contact Info -->
          <div class="card">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Contact Information</h3>
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Address</h4>
                  <p class="text-gray-600">Southwest Iowa Hedge<br>1100 Apple Ave<br>Cumberland, Iowa</p>
                  <p class="text-sm text-gray-500 mt-1">We are 4 miles east of Grant, Iowa.</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Phone</h4>
                  <p class="text-gray-600">712-254-3999</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900">Email</h4>
                  <p class="text-gray-600">cchadww@gmail.com</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Important Notes -->
          <div class="card bg-red-50 border border-red-200">
            <h3 class="text-xl font-semibold text-red-900 mb-4">Important Information</h3>
            <ul class="space-y-2 text-red-800 text-sm">
              <li class="flex items-start space-x-2">
                <svg class="w-4 h-4 text-red-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <span>Fresh cut posts are essential for easy nailing and stapling</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-4 h-4 text-red-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <span>Bow stave logs cannot be shipped - pickup only</span>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-4 h-4 text-red-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <span>We typically sell out every year - order early to secure your posts</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Price calculations
    const prices = {
      premiumLine: 25,
      premiumCorner: 40,
      premiumExtraLong: 60,
      regularLine: 10,
      regularCorner: 25,
      bowStave: 125
    };

    const IS_PREMIUM_EXTRA_LONG_OUT_OF_STOCK = true;

    function readQuantitiesFromForm() {
      const ids = ['premiumLine', 'premiumCorner', 'premiumExtraLong', 'regularLine', 'regularCorner', 'bowStave'];
      /** @type {Record<string, number>} */
      const quantities = {};
      ids.forEach((id) => {
        if (IS_PREMIUM_EXTRA_LONG_OUT_OF_STOCK && id === 'premiumExtraLong') {
          quantities[id] = 0;
        } else {
          quantities[id] = parseInt(document.getElementById(id).value, 10) || 0;
        }
      });
      return quantities;
    }

    function updateOrderSummary() {
      const quantities = readQuantitiesFromForm();

      const summaryDiv = document.getElementById('order-summary');
      const totalDiv = document.getElementById('order-total');
      const discountDiv = document.getElementById('discount-applied');

      let subtotal = 0;
      let totalPosts = 0;
      let summaryHTML = '';

      // Calculate each line item
      Object.keys(quantities).forEach(type => {
        const qty = quantities[type];
        if (qty > 0) {
          const lineTotal = qty * prices[type];
          subtotal += lineTotal;
          totalPosts += qty;

          const typeNames = {
            premiumLine: 'Premium Line Posts',
            premiumCorner: 'Premium Corner Posts',
            premiumExtraLong: 'Premium Extra Long Posts',
            regularLine: 'Regular Line Posts',
            regularCorner: 'Regular Corner Posts',
            bowStave: 'Bow Stave Logs'
          };

          summaryHTML += `
            <div class="flex justify-between">
              <span>${qty} × ${typeNames[type]} ($${prices[type]})</span>
              <span>$${lineTotal.toFixed(2)}</span>
            </div>
          `;
        }
      });

      // Check for volume discount (10% for 100+ posts, excluding bow staves)
      const postCount = totalPosts - quantities.bowStave;
      let total = subtotal;
      let hasDiscount = false;

      if (postCount >= 100) {
        hasDiscount = true;
        total = subtotal * 0.9; // 10% discount
        summaryHTML += `
          <div class="flex justify-between text-green-600 border-t pt-2 mt-2">
            <span>Volume Discount (10%)</span>
            <span>-$${(subtotal * 0.1).toFixed(2)}</span>
          </div>
        `;
      }

      // Update display
      if (subtotal === 0) {
        summaryHTML = '<div class="text-gray-600 text-sm">Select post quantities above to see your total</div>';
      }

      summaryDiv.innerHTML = summaryHTML;
      totalDiv.textContent = `$${total.toFixed(2)}`;
      
      if (hasDiscount) {
        discountDiv.classList.remove('hidden');
      } else {
        discountDiv.classList.add('hidden');
      }

      // Update deposit information
      updateDepositInfo(total);
    }

    function updateDepositInfo(orderTotal) {
      const depositOrderTotalSpan = document.getElementById('deposit-order-total');
      const depositAmountSpan = document.getElementById('deposit-amount');
      
      if (depositOrderTotalSpan && depositAmountSpan) {
        const depositAmount = orderTotal * 0.1;
        depositOrderTotalSpan.textContent = `$${orderTotal.toFixed(2)}`;
        depositAmountSpan.textContent = `$${depositAmount.toFixed(2)}`;
      }
    }

    // Add event listeners to all quantity inputs
    document.addEventListener('DOMContentLoaded', function() {
      const quantityInputs = ['premiumLine', 'premiumCorner', 'premiumExtraLong', 'regularLine', 'regularCorner', 'bowStave'];
      
      quantityInputs.forEach(id => {
        if (IS_PREMIUM_EXTRA_LONG_OUT_OF_STOCK && id === 'premiumExtraLong') return;
        document.getElementById(id).addEventListener('input', updateOrderSummary);
      });

      // Initial calculation
      updateOrderSummary();

      // Deposit option toggle
      const depositCheckbox = document.getElementById('deposit-option');
      const depositDetails = document.getElementById('deposit-details');
      const submitButton = document.getElementById('submit-button');
      const paymentNotice = document.getElementById('payment-notice');
      
      function updateButtonText() {
        if (depositCheckbox && submitButton && paymentNotice) {
          if (depositCheckbox.checked) {
            submitButton.textContent = 'Proceed to Payment';
            paymentNotice.classList.remove('hidden');
          } else {
            submitButton.textContent = 'Submit Order Request';
            paymentNotice.classList.add('hidden');
          }
        }
      }
      
      if (depositCheckbox && depositDetails) {
        depositCheckbox.addEventListener('change', function() {
          if (this.checked) {
            depositDetails.classList.remove('hidden');
          } else {
            depositDetails.classList.add('hidden');
          }
          updateButtonText();
        });
      }
      
      // Initial button text setup
      updateButtonText();
    });

    // Order form handling
    document.getElementById('order-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Get form data
      const formData = new FormData(this);
      const data = Object.fromEntries(formData);
      
      // Get current quantities and totals
      const quantities = readQuantitiesFromForm();

      // Calculate totals
      let subtotal = 0;
      let totalPosts = 0;
      const orderItems = [];

      Object.keys(quantities).forEach(type => {
        const qty = quantities[type];
        if (qty > 0) {
          const lineTotal = qty * prices[type];
          subtotal += lineTotal;
          totalPosts += qty;

          const typeNames = {
            premiumLine: 'Premium Line Posts',
            premiumCorner: 'Premium Corner Posts',
            premiumExtraLong: 'Premium Extra Long Posts',
            regularLine: 'Regular Line Posts',
            regularCorner: 'Regular Corner Posts',
            bowStave: 'Bow Stave Logs'
          };

          orderItems.push({
            type: typeNames[type],
            quantity: qty,
            price: prices[type],
            total: lineTotal
          });
        }
      });

      // Apply volume discount if applicable
      const postCount = totalPosts - quantities.bowStave;
      let orderTotal = subtotal;
      if (postCount >= 100) {
        orderTotal = subtotal * 0.9; // 10% discount
      }

      // Check if deposit option is selected
      const depositCheckbox = document.getElementById('deposit-option');
      const isDepositSelected = depositCheckbox && depositCheckbox.checked;

      if (isDepositSelected && orderTotal > 0) {
        // Process deposit payment through Stripe
        const depositAmount = orderTotal * 0.1; // 10% deposit
        
        const customerInfo = {
          firstName: data.firstName || '',
          lastName: data.lastName || '',
          email: data.email || '',
          phone: data.phone || '',
          address: data.address || '',
          city: data.city || '',
          state: data.state || '',
          zipCode: data.zipCode || '',
          notes: data.message || data.notes || ''
        };

        try {
          // Show loading state
          const submitButton = this.querySelector('button[type="submit"]');
          const originalText = submitButton.textContent;
          submitButton.textContent = 'Processing Payment...';
          submitButton.disabled = true;

          // Create deposit payment session
          const response = await fetch('/api/create-deposit-payment', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              depositAmount,
              orderTotal,
              customerInfo,
              orderItems,
              quantities
            }),
          });

          const result = await response.json();

          if (response.ok && result.url) {
            const emailRes = await fetch('/api/send-order-email', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                customerInfo,
                orderItems,
                quantities,
                orderTotal,
                isDeposit: true,
                depositAmount
              }),
            });
            const emailJson = await emailRes.json().catch(() => ({}));
            if (!emailRes.ok) {
              submitButton.textContent = originalText;
              submitButton.disabled = false;
              alert(
                emailJson.error || emailJson.details
                  ? `We could not email your order: ${emailJson.details || emailJson.error}. Please try again or call 712-254-3999.`
                  : 'We could not email your order. Please try again or call 712-254-3999.'
              );
              return;
            }

            // Redirect to Stripe Checkout
            window.location.href = result.url;
          } else {
            throw new Error(result.error || 'Payment setup failed');
          }
        } catch (error) {
          console.error('Payment error:', error);
          alert('There was an error setting up your payment. Please try again or contact us directly.');
          
          // Reset button state
          const submitButton = this.querySelector('button[type="submit"]');
          submitButton.textContent = originalText;
          submitButton.disabled = false;
        }
      } else {
        // No deposit - just submit order inquiry
        const customerInfo = {
          firstName: data.firstName || '',
          lastName: data.lastName || '',
          email: data.email || '',
          phone: data.phone || '',
          address: data.address || '',
          city: data.city || '',
          state: data.state || '',
          zipCode: data.zipCode || '',
          notes: data.message || data.notes || ''
        };

        const submitBtn = this.querySelector('button[type="submit"]');
        const prevLabel = submitBtn.textContent;
        submitBtn.textContent = 'Sending…';
        submitBtn.disabled = true;

        const emailRes = await fetch('/api/send-order-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customerInfo,
            orderItems,
            quantities,
            orderTotal,
            isDeposit: false,
            depositAmount: 0
          }),
        });
        const emailJson = await emailRes.json().catch(() => ({}));
        submitBtn.textContent = prevLabel;
        submitBtn.disabled = false;

        if (!emailRes.ok) {
          alert(
            emailJson.error || emailJson.details
              ? `We could not send your order: ${emailJson.details || emailJson.error}. Please try again or call 712-254-3999.`
              : 'We could not send your order. Please try again or call 712-254-3999.'
          );
          return;
        }

        alert('Thank you for your order inquiry! We\'ll contact you within 24 hours to confirm details and arrange pickup.');

        this.reset();
        updateOrderSummary();
      }
    });
  </script>
</Layout>