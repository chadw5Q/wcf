---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '';
---

<Layout
  title="Thank You — Order Received | Southwest Iowa Hedge"
  description="Your hedge post or bow stave order request was received. We will contact you within 24 hours."
  ogTitle="Thank you — Southwest Iowa Hedge"
  ogDescription="Your order inquiry was received. We'll contact you soon about pickup in Southwest Iowa."
  image="/images/hedge-posts.jpg"
  noindex={true}
>
  <section class="section-padding bg-green-50">
    <div class="max-w-2xl mx-auto text-center px-4">
      <div class="w-20 h-20 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Thank you!</h1>
      <p class="text-xl text-gray-700 mb-4">
        <strong>Your order is confirmed!</strong> Please choose your delivery day and time using the link below.
      </p>
      <div class="rounded-xl border border-green-200 bg-white p-6 text-left max-w-lg mx-auto mb-8 shadow-sm">
        <a
          href="https://cal.com/chad-williams-donsre/hedge-pickup"
          class="inline-flex w-full justify-center btn-primary text-center mb-4"
          target="_blank"
          rel="noopener noreferrer"
        >
          Schedule pickup / delivery
        </a>
        <p class="text-gray-600 text-sm text-center">
          Need a different day? Text Chad at{' '}
          <a href="tel:+17122543999" class="text-green-700 font-semibold hover:underline">712-254-3999</a>.
        </p>
      </div>
      <p class="text-gray-600 mb-10">
        We’ll also follow up within <strong>24 hours</strong> if anything else is needed. Questions? Text us at{' '}
        <a href="tel:+17122543999" class="text-green-700 font-semibold hover:underline">712-254-3999</a>.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary text-center">Back to home</a>
        <a href="/order-now" class="btn-secondary text-center">Place another order</a>
      </div>
    </div>
  </section>

  {
    measurementId && (
      <script is:inline>
        (function () {
          function fire() {
            if (typeof gtag !== 'function') return false;
            var params = new URLSearchParams(window.location.search);
            var kind = params.get('kind') || 'inquiry';
            gtag('event', 'order_inquiry_thank_you', {
              kind: kind,
              page_path: window.location.pathname + window.location.search,
            });
            gtag('event', 'generate_lead', { currency: 'USD', value: 0 });
            return true;
          }
          var n = 0;
          var t = setInterval(function () {
            if (fire() || ++n > 50) clearInterval(t);
          }, 100);
        })();
      </script>
    )
  }
</Layout>
