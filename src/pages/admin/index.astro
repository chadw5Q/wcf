---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllOrders } from '../../lib/orders';
import { getOrdersKvFromLocals } from '../../lib/orders-kv';
import { formatCentralDateTime, formatUsd } from '../../lib/format-order';
import type { StoredOrder } from '../../lib/order-types';

const kv = getOrdersKvFromLocals(Astro.locals);
const kvMissing = !kv;
const orders = kv ? await getAllOrders(kv) : [];

function sortForHub(list: StoredOrder[]): StoredOrder[] {
  return [...list].sort((a, b) => {
    const sa = a.status === 'scheduled' ? 0 : 1;
    const sb = b.status === 'scheduled' ? 0 : 1;
    if (sa !== sb) return sa - sb;
    return a.createdAt < b.createdAt ? 1 : -1;
  });
}

const previewOrders = sortForHub(orders).slice(0, 10);
---

<AdminLayout title="Admin — Southwest Iowa Hedge">
  {
    kvMissing && (
      <div
        class="no-print mb-6 rounded border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900"
        role="alert"
      >
        <strong>ORDERS_KV is not bound.</strong> Connect KV in wrangler for orders and product config.
      </div>
    )
  }

  <h1 class="mb-6 text-2xl font-bold text-slate-900">Admin</h1>

  <div class="no-print mb-10 grid gap-4 sm:grid-cols-2">
    <a
      href="/admin/products"
      class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition hover:border-green-300 hover:shadow"
    >
      <h2 class="text-lg font-semibold text-green-800">Manage products</h2>
      <p class="mt-2 text-sm text-slate-600">
        Edit /order-now line items (labels, descriptions, prices, sold-out). Same data powers the home page pricing.
      </p>
    </a>
    <a
      href="/admin/all-orders"
      class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition hover:border-green-300 hover:shadow"
    >
      <h2 class="text-lg font-semibold text-green-800">All orders</h2>
      <p class="mt-2 text-sm text-slate-600">Full list, filters, view, and delete.</p>
    </a>
  </div>

  <div class="mb-4 flex flex-wrap items-baseline justify-between gap-2">
    <h2 class="text-xl font-semibold text-slate-900">Orders</h2>
    <a href="/admin/all-orders" class="text-sm font-medium text-green-700 hover:text-green-900">
      All orders →
    </a>
  </div>
  <p class="mb-4 text-sm text-slate-600">
    Latest 10 orders, <strong class="font-medium text-slate-800">scheduled</strong> first, then newest.
  </p>

  <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
    <table class="min-w-full text-left text-sm">
      <thead class="border-b border-slate-200 bg-slate-50 text-slate-600">
        <tr>
          <th class="px-4 py-3 font-medium">Placed (Central)</th>
          <th class="px-4 py-3 font-medium">Customer</th>
          <th class="px-4 py-3 font-medium">Total</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {
          previewOrders.map((o) => (
            <tr class="hover:bg-slate-50/80">
              <td class="px-4 py-3 whitespace-nowrap text-slate-800">{formatCentralDateTime(o.createdAt)}</td>
              <td class="px-4 py-3">
                <a href={`/admin/orders/${o.id}`} class="font-medium text-green-800 hover:underline">
                  {o.customer.name}
                </a>
                <div class="text-xs text-slate-500">{o.customer.email}</div>
              </td>
              <td class="px-4 py-3 tabular-nums font-medium">{formatUsd(o.discountedSubtotal)}</td>
              <td class="px-4 py-3">
                <span class="capitalize">{o.status}</span>
                {o.status === 'scheduled' && o.deliverySlot?.trim() ? (
                  <div class="mt-1 max-w-[14rem] text-xs text-slate-600">{o.deliverySlot.trim()}</div>
                ) : null}
              </td>
              <td class="px-4 py-3">
                <a href={`/admin/orders/${o.id}`} class="text-green-700 hover:text-green-900">
                  View
                </a>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    {previewOrders.length === 0 && !kvMissing && (
      <p class="px-4 py-8 text-center text-slate-500">No orders yet.</p>
    )}
  </div>
</AdminLayout>
