---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllOrders } from '../../lib/orders';
import { getOrdersKvFromLocals } from '../../lib/orders-kv';
import { formatUsd } from '../../lib/format-order';
import {
  defaultReportRangeYmd,
  filterOrdersByCentralDateRange,
} from '../../lib/reports';

const kv = getOrdersKvFromLocals(Astro.locals);
const kvMissing = !kv;
const allOrders = kv ? await getAllOrders(kv) : [];

const defaults = defaultReportRangeYmd();
const fromParam = Astro.url.searchParams.get('from')?.trim() || defaults.from;
const toParam = Astro.url.searchParams.get('to')?.trim() || defaults.to;

const inRange = kvMissing
  ? []
  : filterOrdersByCentralDateRange(allOrders, fromParam, toParam);

const depositSelectedCount = inRange.filter((o) => o.deposit.selected).length;
const totalRevenue = inRange.reduce((s, o) => s + o.discountedSubtotal, 0);
const depositSelectedSubtotal = inRange
  .filter((o) => o.deposit.selected)
  .reduce((s, o) => s + o.discountedSubtotal, 0);
---

<AdminLayout title="Reports — Admin">
  {
    kvMissing && (
      <div class="no-print mb-6 rounded border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900">
        <strong>ORDERS_KV is not bound.</strong> Reports are unavailable until KV is configured.
      </div>
    )
  }

  <div class="no-print mb-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="mb-2 text-2xl font-bold text-slate-900">Reports</h1>
    <p class="mb-6 text-sm text-slate-600">
      Dates use the calendar day in <strong>America/Chicago</strong>. &ldquo;Deposit selected at checkout&rdquo; is
      from the order form only; <strong>paid via Stripe</strong> is not stored in this app — use Stripe for actual
      payments.
    </p>
    <form method="get" class="flex flex-wrap items-end gap-4">
      <div>
        <label for="from" class="mb-1 block text-sm font-medium text-slate-700">From</label>
        <input
          id="from"
          name="from"
          type="date"
          value={fromParam}
          class="rounded border border-slate-300 px-3 py-2 text-slate-900"
        />
      </div>
      <div>
        <label for="to" class="mb-1 block text-sm font-medium text-slate-700">To</label>
        <input
          id="to"
          name="to"
          type="date"
          value={toParam}
          class="rounded border border-slate-300 px-3 py-2 text-slate-900"
        />
      </div>
      <button
        type="submit"
        class="rounded bg-green-700 px-4 py-2 font-medium text-white hover:bg-green-800"
      >
        Apply
      </button>
    </form>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm font-medium text-slate-600">Orders in range</div>
      <div class="mt-2 text-3xl font-bold tabular-nums text-slate-900">{inRange.length}</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm font-medium text-slate-600">Deposit selected at checkout</div>
      <div class="mt-2 text-3xl font-bold tabular-nums text-green-800">{depositSelectedCount}</div>
      <div class="mt-1 text-xs text-slate-500">Not the same as Stripe-paid deposits</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm font-medium text-slate-600">Sum of order totals</div>
      <div class="mt-2 text-2xl font-bold tabular-nums text-slate-900">{formatUsd(totalRevenue)}</div>
      <div class="mt-1 text-xs text-slate-500">After volume discount, before pickup</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm font-medium text-slate-600">Order total (deposit path only)</div>
      <div class="mt-2 text-2xl font-bold tabular-nums text-slate-900">{formatUsd(depositSelectedSubtotal)}</div>
      <div class="mt-1 text-xs text-slate-500">Subtotal of orders that chose deposit at checkout</div>
    </div>
  </div>
</AdminLayout>
