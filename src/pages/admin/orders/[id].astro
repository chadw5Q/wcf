---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getOrder } from '../../../lib/orders';
import { getOrdersKvFromLocals } from '../../../lib/orders-kv';
import { formatCentralDateTime, formatUsd } from '../../../lib/format-order';
import { ORDER_QUANTITY_KEYS } from '../../../lib/order-form-keys';
import type { StoredOrder } from '../../../lib/order-types';

const id = Astro.params.id ?? '';
const kv = getOrdersKvFromLocals(Astro.locals);
const kvMissing = !kv;
const order = kv && id ? await getOrder(kv, id) : null;

function initialQuantities(o: StoredOrder): Record<string, number> {
  const m: Record<string, number> = {};
  for (const k of ORDER_QUANTITY_KEYS) m[k] = 0;
  for (const item of o.items) {
    m[item.fieldName] = item.quantity;
  }
  m.premiumExtraLong = 0;
  return m;
}

const qtyLabels: Record<string, string> = {
  premiumLine: 'Premium line',
  premiumCorner: 'Premium corner / second',
  premiumExtraLong: 'Premium extra long (sold out)',
  regularLine: 'Regular line',
  regularCorner: 'Regular corner',
  bowStave: 'Bow stave',
};

const revisionNewestFirst = order
  ? [...(order.revisionLog ?? [])].reverse()
  : [];
---

<AdminLayout title={order ? `Order ${order.id.slice(0, 8)}…` : 'Order — Admin'}>
  {
    kvMissing && (
      <div class="no-print mb-6 rounded border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900">
        <strong>ORDERS_KV is not bound.</strong> This order cannot be loaded.
      </div>
    )
  }

  {
    !kvMissing && !order && (
      <p class="text-slate-600">
        Order not found. <a href="/admin" class="text-green-700 hover:underline">Back to list</a>
      </p>
    )
  }

  {
    order && (
      <>
        <div class="no-print mb-6 flex flex-wrap items-center gap-4">
          <a href="/admin" class="text-sm font-medium text-green-700 hover:text-green-900">
            ← All orders
          </a>
          <button
            type="button"
            id="print-order"
            class="rounded border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50"
          >
            Print
          </button>
        </div>

        <div class="print-break rounded-lg border border-slate-200 bg-white p-6 shadow-sm print:border print:shadow-none">
          <div class="mb-6 flex flex-wrap justify-between gap-4 border-b border-slate-100 pb-4">
            <div>
              <h1 class="text-2xl font-bold text-slate-900">Order</h1>
              <p class="mt-1 font-mono text-sm text-slate-600">{order.id}</p>
              <p class="text-sm text-slate-600">
                Placed: <span class="font-medium text-slate-800">{formatCentralDateTime(order.createdAt)}</span> (Central)
              </p>
              {order.updatedAt && (
                <p class="text-sm text-slate-500">
                  Last updated: {formatCentralDateTime(order.updatedAt)} (Central)
                </p>
              )}
            </div>
            <div class="text-right text-sm text-slate-600">
              <div>
                Status: <span class="font-semibold capitalize text-slate-900">{order.status}</span>
              </div>
              {order.deliverySlot && (
                <div class="mt-1">
                  Delivery / pickup slot:{' '}
                  <span class="font-medium text-slate-800">{order.deliverySlot}</span>
                </div>
              )}
            </div>
          </div>

          <div class="grid gap-8 md:grid-cols-2 print-break">
            <div>
              <h2 class="mb-2 text-lg font-semibold text-slate-900">Customer</h2>
              <ul class="space-y-1 text-slate-700">
                <li>{order.customer.name}</li>
                <li>
                  <a href={`mailto:${order.customer.email}`} class="text-green-700 hover:underline">
                    {order.customer.email}
                  </a>
                </li>
                <li>{order.customer.phone || '—'}</li>
              </ul>
            </div>
            <div>
              <h2 class="mb-2 text-lg font-semibold text-slate-900">Totals</h2>
              <ul class="space-y-1 text-sm text-slate-700">
                <li class="flex justify-between gap-4">
                  <span>Subtotal</span>
                  <span class="tabular-nums">{formatUsd(order.subtotal)}</span>
                </li>
                {order.volumeDiscount.applied && (
                  <li class="flex justify-between gap-4 text-green-800">
                    <span>Volume discount (10%)</span>
                    <span class="tabular-nums">−{formatUsd(order.volumeDiscount.amount)}</span>
                  </li>
                )}
                <li class="flex justify-between gap-4 font-semibold text-slate-900">
                  <span>Order total</span>
                  <span class="tabular-nums">{formatUsd(order.discountedSubtotal)}</span>
                </li>
                <li class="flex justify-between gap-4">
                  <span>Deposit selected at checkout</span>
                  <span class="tabular-nums">
                    {order.deposit.selected ? `Yes — ${formatUsd(order.depositAmount)}` : 'No'}
                  </span>
                </li>
                <li class="rounded border border-slate-100 bg-slate-50 px-3 py-2 text-xs text-slate-600 no-print">
                  This flag cannot be edited here. If quantities or totals change, the deposit amount is recalculated only
                  when a deposit was originally selected. Stripe charges are not updated automatically.
                </li>
                <li class="text-xs text-slate-500">
                  Stripe capture is not shown here; check the Stripe dashboard for paid deposits.
                </li>
                <li class="flex justify-between gap-4 border-t border-slate-100 pt-2 font-medium">
                  <span>Balance due (estimated)</span>
                  <span class="tabular-nums">{formatUsd(order.balanceDue)}</span>
                </li>
              </ul>
            </div>
          </div>

          <div class="mt-8 print-break">
            <h2 class="mb-3 text-lg font-semibold text-slate-900">Line items</h2>
            <table class="w-full text-sm">
              <thead class="border-b border-slate-200 text-left text-slate-600">
                <tr>
                  <th class="py-2 pr-4 font-medium">Product</th>
                  <th class="py-2 pr-4 font-medium">Qty</th>
                  <th class="py-2 pr-4 font-medium">Unit</th>
                  <th class="py-2 font-medium">Line</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100" id="line-items-body">
                {order.items.map((i) => (
                  <tr>
                    <td class="py-2 pr-4">{i.product}</td>
                    <td class="py-2 pr-4 tabular-nums">{i.quantity}</td>
                    <td class="py-2 pr-4 tabular-nums">{formatUsd(i.unitPrice)}</td>
                    <td class="py-2 tabular-nums font-medium">{formatUsd(i.lineTotal)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="mt-8 print-break rounded border border-slate-100 bg-slate-50 p-4">
            <h2 class="mb-2 font-semibold text-slate-900">Notes</h2>
            <p class="whitespace-pre-wrap text-slate-700">{order.notes || '—'}</p>
          </div>

          <div class="no-print mt-10 border-t border-slate-200 pt-8">
            <h2 class="mb-2 text-lg font-semibold text-slate-900">Edit order</h2>
            <p class="mb-6 text-sm text-slate-600">
              Quantities and customer fields are recalculated on the server (same pricing rules as checkout). Deposit
              at checkout is <strong>not</strong> editable.
            </p>
            <form id="admin-order-form" class="max-w-2xl space-y-6">
              <input type="hidden" name="id" value={order.id} />

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="firstName" class="mb-1 block text-sm font-medium text-slate-700">First name</label>
                  <input
                    id="firstName"
                    name="firstName"
                    type="text"
                    required
                    value={order.customer.firstName}
                    class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                  />
                </div>
                <div>
                  <label for="lastName" class="mb-1 block text-sm font-medium text-slate-700">Last name</label>
                  <input
                    id="lastName"
                    name="lastName"
                    type="text"
                    required
                    value={order.customer.lastName}
                    class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                  />
                </div>
              </div>
              <div>
                <label for="email" class="mb-1 block text-sm font-medium text-slate-700">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  value={order.customer.email}
                  class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                />
              </div>
              <div>
                <label for="phone" class="mb-1 block text-sm font-medium text-slate-700">Phone</label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  value={order.customer.phone}
                  class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                />
              </div>

              <div>
                <h3 class="mb-3 text-sm font-semibold text-slate-900">Quantities</h3>
                <div class="grid gap-3 sm:grid-cols-2">
                  {ORDER_QUANTITY_KEYS.map((key) => {
                    const disabled = key === 'premiumExtraLong';
                    const val = initialQuantities(order)[key];
                    return (
                      <div class={disabled ? 'opacity-60' : ''}>
                        <label for={`qty-${key}`} class="mb-1 block text-xs font-medium text-slate-700">
                          {qtyLabels[key] ?? key}
                        </label>
                        <input
                          id={`qty-${key}`}
                          name={`qty_${key}`}
                          type="number"
                          min="0"
                          step="1"
                          value={disabled ? 0 : val}
                          disabled={disabled}
                          class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900 disabled:bg-slate-100"
                        />
                      </div>
                    );
                  })}
                </div>
              </div>

              <div>
                <label for="notes" class="mb-1 block text-sm font-medium text-slate-700">Notes</label>
                <textarea
                  id="notes"
                  name="notes"
                  rows="4"
                  class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                >
                  {order.notes ?? ''}
                </textarea>
              </div>

              <div class="border-t border-slate-100 pt-6">
                <h3 class="mb-3 text-sm font-semibold text-slate-900">Status & pickup</h3>
                <div class="space-y-4">
                  <div>
                    <label for="status" class="mb-1 block text-sm font-medium text-slate-700">Status</label>
                    <select
                      id="status"
                      name="status"
                      class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                    >
                      <option value="pending" selected={order.status === 'pending'}>Pending</option>
                      <option value="confirmed" selected={order.status === 'confirmed'}>Confirmed</option>
                      <option value="fulfilled" selected={order.status === 'fulfilled'}>Fulfilled</option>
                    </select>
                  </div>
                  <div>
                    <label for="deliverySlot" class="mb-1 block text-sm font-medium text-slate-700">
                      Delivery / pickup slot
                    </label>
                    <input
                      id="deliverySlot"
                      name="deliverySlot"
                      type="text"
                      value={order.deliverySlot ?? ''}
                      placeholder="e.g. Sat Apr 12, 9–11am"
                      class="w-full rounded border border-slate-300 px-3 py-2 text-slate-900"
                    />
                  </div>
                </div>
              </div>

              <p id="update-msg" class="hidden text-sm"></p>
              <button
                type="submit"
                class="rounded bg-green-700 px-4 py-2 font-medium text-white hover:bg-green-800"
              >
                Save changes
              </button>
            </form>
          </div>

          {revisionNewestFirst.length > 0 && (
            <div class="no-print mt-10 border-t border-slate-200 pt-8">
              <h2 class="mb-4 text-lg font-semibold text-slate-900">Revision log</h2>
              <p class="mb-4 text-sm text-slate-600">Newest first. Up to 100 entries are kept.</p>
              <ul class="space-y-4">
                {revisionNewestFirst.map((entry) => (
                  <li class="rounded-lg border border-slate-100 bg-slate-50/80 p-4 text-sm">
                    <div class="flex flex-wrap items-baseline justify-between gap-2">
                      <span class="font-medium text-slate-900">{entry.summary}</span>
                      <time class="text-xs text-slate-500 tabular-nums">{formatCentralDateTime(entry.at)}</time>
                    </div>
                    <p class="mt-1 text-xs uppercase tracking-wide text-slate-500">{entry.action}</p>
                    {entry.details && Object.keys(entry.details).length > 0 && (
                      <details class="mt-2">
                        <summary class="cursor-pointer text-xs font-medium text-green-800">Technical details</summary>
                        <pre class="mt-2 max-h-48 overflow-auto rounded bg-white p-2 text-xs text-slate-700">{JSON.stringify(entry.details, null, 2)}</pre>
                      </details>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <script>
          import { ORDER_QUANTITY_KEYS } from '../../../lib/order-form-keys';

          document.getElementById('print-order')?.addEventListener('click', () => window.print());

          document.getElementById('admin-order-form')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            if (!(form instanceof HTMLFormElement)) return;
            const msg = document.getElementById('update-msg');
            const idEl = form.querySelector('[name="id"]');
            if (!(idEl instanceof HTMLInputElement)) return;

            const quantities: Record<string, number> = {};
            for (const key of ORDER_QUANTITY_KEYS) {
              const el = form.querySelector(`[name="qty_${key}"]`);
              if (el instanceof HTMLInputElement) {
                quantities[key] = Math.max(0, parseInt(el.value, 10) || 0);
              }
            }

            const firstName = (form.querySelector('[name="firstName"]') as HTMLInputElement)?.value ?? '';
            const lastName = (form.querySelector('[name="lastName"]') as HTMLInputElement)?.value ?? '';
            const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value ?? '';
            const phone = (form.querySelector('[name="phone"]') as HTMLInputElement)?.value ?? '';
            const notes = (form.querySelector('[name="notes"]') as HTMLTextAreaElement)?.value ?? '';
            const status = (form.querySelector('[name="status"]') as HTMLSelectElement)?.value ?? '';
            const deliverySlot = (form.querySelector('[name="deliverySlot"]') as HTMLInputElement)?.value ?? '';

            const body = {
              id: idEl.value,
              status,
              deliverySlot: deliverySlot.trim() || null,
              rebuild: {
                firstName,
                lastName,
                email,
                phone,
                notes: notes.trim() || null,
                quantities,
              },
            };

            const res = await fetch('/api/admin/update-order', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            const data = await res.json().catch(() => ({}));
            if (msg) {
              msg.classList.remove('hidden', 'text-red-600', 'text-green-800');
              if (res.ok) {
                msg.classList.add('text-green-800');
                msg.textContent = data.unchanged ? 'No changes to save.' : 'Saved.';
                if (!data.unchanged) window.location.reload();
              } else {
                msg.classList.add('text-red-600');
                msg.textContent = data.error || data.details || 'Save failed.';
              }
            }
          });
        </script>
      </>
    )
  }
</AdminLayout>

