---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Southwest Iowa Hedge - Premium Hedge Posts for Fencing & Archery">
  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="background-image: url('/images/hedge002.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
    <div class="absolute inset-0 bg-black opacity-40"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 section-padding">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            Premium Hedge Posts for
            <span class="text-green-400">Permanent Fencing</span>
          </h1>
          <p class="text-xl text-gray-200 mb-8 leading-relaxed">
            Hedge is the perfect post for permanent fencing and archery bow staves. Scroll to the bottom to read about the bow staves.
          </p>


          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#pricing-content" class="btn-primary text-center">
              View Pricing
            </a>
            <a href="/order-now" class="btn-secondary text-center">
              Order Now
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="bg-green-600 rounded-2xl p-8 text-white">
            <div class="text-center">
              <div class="text-6xl mb-4">🌳</div>
              <h3 class="text-2xl font-bold mb-2">50+ Years Strong</h3>
              <p class="text-green-100">Hedge posts have proven durability for generations</p>
            </div>
          </div>
          <div class="bg-green-50 border-l-4 border-green-400 p-4 mt-6 rounded-r-lg">
            <p class="text-green-800 font-medium">
              My grandfather used hedge for his fencing back in 1962. They were still standing strong when my father replaced the fence in 2018, 56 years later.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="section-padding bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <!-- Benefits of Hedge Posts Section -->
      <div class="mb-20">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Why Choose Hedge Posts for Your Fencing?
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Hedge (Osage Orange) posts are the gold standard for permanent fencing. 
            Here's why ranchers and farmers have trusted them for generations.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Durability -->
          <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 text-center">
            <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13a1 1 0 102 0V9.414l1.293 1.293a1 1 0 001.414-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Exceptional Durability</h3>
            <p class="text-gray-700">
              Hedge posts can last 50+ years in the ground. The natural rot resistance means your fence investment pays off for decades.
            </p>
          </div>

          <!-- Strength -->
          <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 text-center">
            <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
