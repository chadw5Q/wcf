---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Outfitter Services - Southwest Iowa Hedge"
  description="Outfitter and land services from Williams Creek Farms, Southwest Iowa. Contact us for hedge posts, land management, and outdoor partnerships."
  ogTitle="Outfitter services — Southwest Iowa Hedge"
  ogDescription="Land and outfitter services from our Southwest Iowa farm."
  image="/images/hedge002.jpg"
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-amber-50 to-amber-100 overflow-hidden">
    <div class="absolute inset-0 bg-amber-600 opacity-10"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 section-padding">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
            Professional
            <span class="text-amber-600">Outfitter</span>
            Services
          </h1>
          <p class="text-xl text-gray-600 mb-8 leading-relaxed">
            Experience the great outdoors with our professional outfitter services. 
            From guided tours to equipment rentals, we provide everything you need 
            for your outdoor adventures.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="btn-secondary text-center">
              Book Your Adventure
            </a>
            <a href="#services" class="border-2 border-amber-600 text-amber-600 hover:bg-amber-600 hover:text-white font-semibold py-3 px-8 rounded-lg transition-colors duration-200 text-center">
              View Services
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="bg-amber-600 rounded-2xl p-8 text-white">
            <div class="text-center">
              <div class="text-6xl mb-4">🏕️</div>
              <h3 class="text-2xl font-bold mb-2">Expert Guides</h3>
              <p class="text-amber-100">Professional outfitters with years of experience in the outdoors</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Our Outfitter Services
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          From guided tours to equipment rentals, we provide comprehensive outfitter services 
          for all your outdoor needs.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service 1 -->
        <div class="card text-center group hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🏔️</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Guided Tours</h3>
          <p class="text-gray-600 mb-6">
            Expert-led tours through the most beautiful trails and scenic areas. 
            Perfect for groups and families.
          </p>
          <div class="text-2xl font-bold text-amber-600 mb-4">From $75/person</div>
          <a href="/contact" class="btn-secondary">
            Book Now
          </a>
        </div>
        
        <!-- Service 2 -->
        <div class="card text-center group hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🎒</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Equipment Rental</h3>
          <p class="text-gray-600 mb-6">
            High-quality camping, hiking, and outdoor equipment available for rent. 
            Everything you need for your adventure.
          </p>
          <div class="text-2xl font-bold text-amber-600 mb-4">From $25/day</div>
          <a href="/contact" class="btn-secondary">
            Reserve Equipment
          </a>
        </div>
        
        <!-- Service 3 -->
        <div class="card text-center group hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🏕️</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Camping Packages</h3>
          <p class="text-gray-600 mb-6">
            Complete camping packages including setup, equipment, and guided activities. 
            Perfect for beginners and families.
          </p>
          <div class="text-2xl font-bold text-amber-600 mb-4">From $150/night</div>
          <a href="/contact" class="btn-secondary">
            Book Package
          </a>
        </div>
        
        <!-- Service 4 -->
        <div class="card text-center group hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🎣</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Fishing Trips</h3>
          <p class="text-gray-600 mb-6">
            Guided fishing trips on local rivers and lakes. 
            Equipment and licenses included.
          </p>
          <div class="text-2xl font-bold text-amber-600 mb-4">From $100/person</div>
          <a href="/contact" class="btn-secondary">
            Book Fishing Trip
          </a>
        </div>
        
        <!-- Service 5 -->
        <div class="card text-center group hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🚴</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Bike Tours</h3>
          <p class="text-gray-600 mb-6">
            Scenic bike tours through beautiful countryside. 
            Bikes and safety equipment provided.
          </p>
          <div class="text-2xl font-bold text-amber-600 mb-4">From $45/person</div>
          <a href="/contact" class="btn-secondary">
            Book Bike Tour
          </a>
        </div>
        
        <!-- Service 6 -->
        <div class="card text-center group hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">📚</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Outdoor Education</h3>
          <p class="text-gray-600 mb-6">
            Learn outdoor skills, survival techniques, and nature appreciation. 
            Perfect for schools and groups.
          </p>
          <div class="text-2xl font-bold text-amber-600 mb-4">From $30/person</div>
          <a href="/contact" class="btn-secondary">
            Book Class
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="section-padding bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Why Choose Our Outfitter Services?
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We're committed to providing safe, educational, and memorable outdoor experiences
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Feature 1 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Safety First</h3>
          <p class="text-gray-600 text-sm">
            All guides are certified and safety equipment is regularly inspected
          </p>
        </div>
        
        <!-- Feature 2 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Experienced Guides</h3>
          <p class="text-gray-600 text-sm">
            Professional guides with years of outdoor experience and local knowledge
          </p>
        </div>
        
        <!-- Feature 3 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Quality Equipment</h3>
          <p class="text-gray-600 text-sm">
            Top-quality, well-maintained equipment for all outdoor activities
          </p>
        </div>
        
        <!-- Feature 4 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Group Friendly</h3>
          <p class="text-gray-600 text-sm">
            Perfect for families, schools, and corporate team building events
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          What Our Customers Say
        </h2>
        <p class="text-xl text-gray-600">
          Don't just take our word for it - hear from our satisfied customers
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="card">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-xl font-bold text-amber-600">S</span>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900">Sarah Johnson</h4>
              <p class="text-sm text-gray-600">Family Trip</p>
            </div>
          </div>
          <p class="text-gray-600">
            "Amazing guided tour! Our guide was knowledgeable and made the experience 
            perfect for our family. The kids loved learning about the local wildlife."
          </p>
          <div class="flex text-amber-400 mt-4">
            ★★★★★
          </div>
        </div>
        
        <!-- Testimonial 2 -->
        <div class="card">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-xl font-bold text-amber-600">M</span>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900">Mike Chen</h4>
              <p class="text-sm text-gray-600">Camping Package</p>
            </div>
          </div>
          <p class="text-gray-600">
            "The camping package was perfect for our first-time camping experience. 
            Everything was set up and ready when we arrived. Highly recommend!"
          </p>
          <div class="flex text-amber-400 mt-4">
            ★★★★★
          </div>
        </div>
        
        <!-- Testimonial 3 -->
        <div class="card">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-xl font-bold text-amber-600">L</span>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900">Lisa Rodriguez</h4>
              <p class="text-sm text-gray-600">Fishing Trip</p>
            </div>
          </div>
          <p class="text-gray-600">
            "The fishing trip was incredible! Our guide knew all the best spots and 
            we caught more fish than we expected. Will definitely book again."
          </p>
          <div class="flex text-amber-400 mt-4">
            ★★★★★
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-amber-600 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Ready for Your Next Adventure?
      </h2>
      <p class="text-xl mb-8 text-amber-100">
        Book your outfitter experience today and create memories that will last a lifetime.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-amber-600 hover:bg-gray-100 font-semibold py-3 px-8 rounded-lg transition-colors duration-200">
          Book Now
        </a>
        <a href="/hedge-posts" class="border-2 border-white text-white hover:bg-white hover:text-amber-600 font-semibold py-3 px-8 rounded-lg transition-colors duration-200">
          View Hedge Plants
        </a>
      </div>
    </div>
  </section>
</Layout> 