---
import { getOrderSkuImageSrc, type OrderSkuRow } from '../lib/products-config';

interface Props {
  sku: OrderSkuRow;
  variant: 'premium' | 'regular' | 'bow';
}

const { sku, variant } = Astro.props;

const rawBullets = sku.shortDescription
  .split(',')
  .map((s) => s.trim())
  .filter(Boolean);
const bullets =
  rawBullets.length > 0 ? rawBullets : [sku.shortDescription.trim() || 'See order form for details.'];

const priceText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(
  sku.unitPrice
);

const imgSrc = getOrderSkuImageSrc(sku, sku.fieldName);
const alt = `${sku.label} — ${sku.shortDescription}`;

const cardClass =
  variant === 'regular'
    ? 'rounded-xl p-6 border border-yellow-400'
    : 'rounded-xl p-6 border border-green-400';

const cardStyle =
  variant === 'regular' ? 'background-color: #fff5d1;' : 'background-color: #b8f1c5;';

const ctaClass =
  variant === 'regular'
    ? 'w-full bg-yellow-600 text-white text-center py-2 px-4 rounded-lg hover:bg-yellow-700 transition-colors duration-200 block font-medium'
    : 'w-full bg-green-600 text-white text-center py-2 px-4 rounded-lg hover:bg-green-700 transition-colors duration-200 block font-medium';
---

<div class={cardClass} style={cardStyle}>
  {
    (sku.soldOut || variant === 'premium') && (
      <div
        class:list={[
          'mb-3 flex flex-wrap items-center gap-2',
          sku.soldOut && variant === 'premium' ? 'justify-between' : 'justify-end',
        ]}
      >
        {sku.soldOut && (
          <span class="bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full shrink-0">SOLD OUT</span>
        )}
        {variant === 'premium' && (
          <span class="bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full shrink-0">PREMIUM</span>
        )}
      </div>
    )
  }
  <div class="text-center mb-4">
    <h4 class="text-xl font-bold text-gray-900 mb-2">{sku.label}</h4>
    <div class:list={['text-4xl font-bold mb-4', variant === 'regular' ? 'text-green-600' : 'text-green-700']}>
      {priceText}
    </div>
    {variant === 'bow' && <div class="text-gray-600">per log</div>}
  </div>
  <div class="flex gap-4">
    <ul class="space-y-3 flex-grow">
      {
        bullets.map((text) => (
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
            <span class="text-gray-700">{text}</span>
          </li>
        ))
      }
    </ul>
    <div class="flex-shrink-0">
      <img src={imgSrc} alt={alt} class="w-50 h-44 object-cover rounded-lg" width="200" height="176" />
    </div>
  </div>
  {
    variant === 'bow' && (
      <div class="bg-white bg-opacity-50 rounded-lg p-3 mb-4 mt-4">
        <div class="flex items-center text-sm">
          <svg class="w-4 h-4 text-red-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
              clip-rule="evenodd"
            />
          </svg>
          <span class="text-gray-700">We cannot ship bow stave logs</span>
        </div>
      </div>
    )
  }
  <div class="mt-6">
    {
      sku.soldOut ? (
        <span
          class="w-full bg-gray-400 text-white text-center py-2 px-4 rounded-lg block font-medium cursor-not-allowed"
          aria-disabled="true"
        >
          Sold Out
        </span>
      ) : (
        <a href="/order-now" class={ctaClass}>
          Order Now
        </a>
      )
    }
  </div>
</div>
